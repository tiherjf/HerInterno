{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/qualidade/notificacoes",
      "schedule": "0 11 * * 1-5"
    },
    {
      "path": "/api/chat-interno/expurgo",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/chamados/alertas-sla",
      "schedule": "0 11-21/2 * * 1-5"
    },
    {
      "path": "/api/chamados/preventivas/gerar",
      "schedule": "0 6 * * *"
    }
  ]
}
