# ============================================================
# Variáveis de ambiente — Intranet HER
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# Supabase — obtenha em https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...service-role-key...

# JWT para autenticação de pacientes (gere um secret forte)
# Exemplo: openssl rand -base64 32
JWT_PATIENT_SECRET=mude-este-valor-para-um-secret-forte-em-producao

# GLPI — sistema de chamados
GLPI_URL=http://192.168.0.250/glpi
GLPI_API_TOKEN=seu-token-de-api-do-glpi
GLPI_APP_TOKEN=

# OpenClaw — gateway de IA local
OPENCLAW_URL=http://127.0.0.1:18789

# Armazenamento de vídeos dos exames (path no servidor)
VIDEO_STORAGE_PATH=/mnt/exames

# Resend — e-mails de confirmação (opcional)
RESEND_API_KEY=re_xxxxxxxxxxxx

# ============================================================
# NOTAS DE SEGURANÇA
# - Nunca commite este arquivo com valores reais
# - SUPABASE_SERVICE_ROLE_KEY não deve ter prefixo NEXT_PUBLIC_
# - JWT_PATIENT_SECRET deve ser único por ambiente
# ============================================================
